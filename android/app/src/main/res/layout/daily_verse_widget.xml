<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_verse_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header with title and refresh button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Daily Verse"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_refresh"
            android:contentDescription="Refresh verse"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Verse text -->
    <TextView
        android:id="@+id/widget_verse_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Trust in the Lord with all your heart"
        android:textSize="14sp"
        android:textColor="#34495E"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="6"
        android:ellipsize="end"
        android:layout_marginBottom="8dp" />

    <!-- Reference -->
    <TextView
        android:id="@+id/widget_verse_reference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proverbs 3:5-6"
        android:textSize="12sp"
        android:textColor="#7F8C8D"
        android:textStyle="italic"
        android:gravity="end" />

</LinearLayout>

